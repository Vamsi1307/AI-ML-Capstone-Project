{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "python: activate venv",
      "type": "shell",
      "command": "echo",
      "args": ["Virtual environment is managed by VS Code Python extension."],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "Run FastAPI Server",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "uvicorn",
        "main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--reload"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*Uvicorn running.*",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Uvicorn running.*",
          "endsPattern": "^.*Application startup complete.*"
        }
      }
    },
    {
      "label": "Run Tests",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "pytest",
        "test_basic.py",
        "-v",
        "-s"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "new"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*?):(\\d+): (error|warning|info): (.*)$",
          "file": 1,
          "location": 2,
          "severity": 3,
          "message": 4
        }
      }
    },
    {
      "label": "Format Code with Black",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "black",
        "app/",
        "main.py",
        "--line-length=100"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "group": "build"
    },
    {
      "label": "Lint with Flake8",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "flake8",
        "app/",
        "main.py",
        "--max-line-length=100"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "group": "build",
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*?):(\\d+):(\\d+): ([A-Z]\\d+) (.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "code": 4,
          "message": 5
        }
      }
    },
    {
      "label": "Type Check with MyPy",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "mypy",
        "app/",
        "main.py",
        "--ignore-missing-imports"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "group": "build",
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*?):(\\d+): (error|note): (.*)$",
          "file": 1,
          "line": 2,
          "severity": 3,
          "message": 4
        }
      }
    },
    {
      "label": "Install Dependencies",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "pip",
        "install",
        "-r",
        "requirements.txt"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "new"
      },
      "group": "build"
    },
    {
      "label": "Health Check API",
      "type": "shell",
      "command": "curl",
      "args": [
        "http://localhost:8000/api/v1/health-check"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "group": "test"
    },
    {
      "label": "View API Docs",
      "type": "shell",
      "command": "start",
      "args": [
        "http://localhost:8000/docs"
      ],
      "windows": {
        "command": "cmd",
        "args": [
          "/c",
          "start http://localhost:8000/docs"
        ]
      },
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared"
      },
      "group": "test"
    }
  ]
}
