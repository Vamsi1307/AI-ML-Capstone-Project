# API Configuration
DEBUG=False
HOST=0.0.0.0
PORT=8000

# ========== LLM PROVIDERS CONFIGURATION ==========
# Enable at least ONE provider below

# ===== OPENAI =====
OPENAI_ENABLED=true
OPENAI_API_KEY=sk-proj-xxxx
OPENAI_MODEL=gpt-5

# ===== LOCAL LLM =====
LOCAL_LLM_ENABLED=false
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3

# ========== EMBEDDING CONFIGURATION ==========
EMBEDDING_MODEL=text-embedding-3-large

# Vector Storage
VECTOR_STORE_PATH=app/data/vectors
VECTOR_STORE_TYPE=faiss

# Document Processing
MAX_FILE_SIZE_MB=100
CHUNK_SIZE=200
CHUNK_OVERLAP=50
CHUNKING_STRATEGY=overlap

# Retrieval Configuration
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.3

# Agent Configuration
MAX_REACT_ITERATIONS=2

# Preprocessing Configuration
# Set to true to use LLM for chunk summaries/titles (slower uploads, better retrieval)
ENABLE_CHUNK_SUMMARIES=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
