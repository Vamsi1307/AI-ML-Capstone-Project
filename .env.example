# API Configuration
DEBUG=False
HOST=0.0.0.0
PORT=8000

# ========== LLM PROVIDERS CONFIGURATION ==========
# Enable at least ONE provider below by setting ENABLED=true
# and providing the required API key/URL for that provider

# ===== OPENAI =====
# Get API key from: https://platform.openai.com/api-keys
OPENAI_ENABLED=false
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4

# ===== LOCAL LLM (OLLAMA) =====
# Use a local LLM server like Ollama (no API key required)
# Make sure your local LLM server is running and accessible
# Default Ollama URL: http://localhost:11434
LOCAL_LLM_ENABLED=false
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama2

# ========== EMBEDDING CONFIGURATION ==========
EMBEDDING_MODEL=text-embedding-ada-002

# Vector Storage
VECTOR_STORE_PATH=app/data/vectors
VECTOR_STORE_TYPE=faiss

# Document Processing
MAX_FILE_SIZE_MB=100
CHUNK_SIZE=200
CHUNK_OVERLAP=50
CHUNKING_STRATEGY=overlap

# Retrieval Configuration
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.3

# Agent Configuration
# Maximum ReAct loop iterations per query (prevents runaway LLM calls)
MAX_REACT_ITERATIONS=5

# Preprocessing Configuration
# Set to true to use LLM for generating chunk summaries and semantic titles
# Improves retrieval quality but makes document uploads slower (1 LLM call per chunk)
ENABLE_CHUNK_SUMMARIES=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
